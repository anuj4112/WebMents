  "faqs": [
    {
      "question": "How do I register as a manufacturer?",
      "answer": "Click on 'Get Started', select 'Manufacturer' role, fill in your business details, and upload your logo. You'll be able to start adding products immediately after registration."
    },
    {
      "question": "What is the minimum order quantity?",
      "answer": "Minimum order quantity varies by product and manufacturer. It's typically mentioned in the product details. Most manufacturers accept orders starting from 50-100 pieces."
    },
    {
      "question": "How do I contact a manufacturer?",
      "answer": "You can view the manufacturer's contact details on their profile page. Click on any manufacturer card to see their email and phone number."
    },
    {
      "question": "Is there any commission or fee?",
      "answer": "Currently, WebMents is free for all users. We don't charge any commission on transactions."
    },
    {
      "question": "How do I track my orders?",
      "answer": "Manufacturers can view all orders in their dashboard. Buyers can contact manufacturers directly for order status updates."
    },
    {
      "question": "Can I export products internationally?",
      "answer": "Yes! Many manufacturers on our platform handle international orders. Contact them directly to discuss export requirements and shipping."
    }
  ]
}
